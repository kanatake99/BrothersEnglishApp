@using BrothersEnglishApp.Services
@inject UserContext Context
@inject NavigationManager Nav

<div class="top-row ps-3 navbar bg-primary shadow-sm">
    <div class="container-fluid">
        <a class="navbar-brand text-light fw-bold" href="">BrothersEnglishApp</a>
        <button title="Navigation menu" class="navbar-toggler border-light"
                aria-expanded="@AriaExpandedValue"
                @onclick="ToggleNavMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
    </div>
</div>

<div class="@NavMenuCssClass nav-scrollable bg-white border-end shadow" @onclick="ToggleNavMenu">
    <nav class="nav flex-column py-2">
        @* --- ホーム --- *@
        <div class="nav-item px-3 mb-1">
            <NavLink class="nav-link rounded px-3 py-2 text-primary-emphasis" href="" Match="NavLinkMatch.All">
                <span class="me-3 fs-4">🏠</span> <span class="fw-bold">ホーム</span>
            </NavLink>
        </div>

        <hr class="mx-3 my-2 text-muted">

        @* --- 単語セクション --- *@
        <div class="px-4 py-1 small text-muted text-uppercase fw-bold" style="font-size: 0.75rem;">単語の学習</div>
        <div class="nav-item px-3">
            <NavLink class="nav-link rounded px-3 py-2" href="study">
                <span class="me-3 fs-4">📝</span> <span>単語を覚える</span>
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link rounded px-3 py-2" href="training">
                <span class="me-3 fs-4">🏁</span> <span>単語の復習</span>
            </NavLink>
        </div>

        <hr class="mx-3 my-2 text-muted">

        @* --- 文セクション (✨新機能) --- *@
        <div class="px-4 py-1 small text-muted text-uppercase fw-bold" style="font-size: 0.75rem;">文の学習</div>
        <div class="nav-item px-3">
            <NavLink class="nav-link rounded px-3 py-2" href="sentence-study">
                <span class="me-3 fs-4">📖</span> <span>文を覚える</span>
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link rounded px-3 py-2" href="sentence-training">
                <span class="me-3 fs-4">📋</span> <span>文の復習</span>
            </NavLink>
        </div>

        <hr class="mx-3 my-2 text-muted">

        @* --- データセクション --- *@
        <div class="px-4 py-1 small text-muted text-uppercase fw-bold" style="font-size: 0.75rem;">データ</div>
        <div class="nav-item px-3">
            <NavLink class="nav-link rounded px-3 py-2" href="report">
                <span class="me-3 fs-4">🏆</span> <span>成績表</span>
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link rounded px-3 py-2" href="wordlist">
                <span class="me-3 fs-4">📍</span> <span>単語リスト</span>
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link rounded px-3 py-2" href="sentence-list">
                <span class="me-3 fs-4">📰</span> <span>文リスト</span>
            </NavLink>
        </div>
        
        <hr class="mx-3 my-2 text-muted">

        @* --- 設定セクション --- *@
        <div class="px-4 py-1 small text-muted text-uppercase fw-bold" style="font-size: 0.75rem;">設定</div>
        <div class="nav-item px-3">
            <NavLink class="nav-link rounded px-3 py-2" href="/settings">
                <span class="me-3 fs-4">⚙️</span> <span>設定</span>
            </NavLink>
        </div>

    </nav>
</div>

@code {
    private bool collapseNavMenu = true;
    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;
    private string AriaExpandedValue => (!collapseNavMenu).ToString().ToLower();

    private void ToggleNavMenu() => collapseNavMenu = !collapseNavMenu;

    private async Task HandleLogout()
    {
        await Context.LogoutAsync();
        Nav.NavigateTo("/", forceLoad: true);
    }
}