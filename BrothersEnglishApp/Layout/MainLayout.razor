@inherits LayoutComponentBase
@inject UserContext UserContext
@inject NavigationManager Nav
@inject IJSRuntime JS
@* アップデート実行中のオーバーレイ *@
@if (_isUpdating)
{
    <div class="update-overlay">
        <div class="text-center text-white">
            <div class="spinner-border mb-3" style="width: 3rem; height: 3rem;"></div>
            <h4>アップデートを適用中...</h4>
            <p>最新の単語データを準備しています。少々お待ちください。</p>
        </div>
    </div>
}
@if (_isInitialized)
{
    @if (UserContext.IsLoggedIn)
    {
        @* ログイン済み：通常のサイドバー付きレイアウト *@
        <div class="page">
            <div class="sidebar">
                <NavMenu />
            </div>
            <main>
                <article class="content px-3">
                    @Body
                </article>
            </main>
        </div>
    }
    else
    {
        @* 未ログイン：ログイン画面を表示 *@
        <BrothersEnglishApp.Pages.Login />
    }
}
@if (_newVersionAvailable)
{
    <div class="alert alert-info d-flex justify-content-between align-items-center m-3 shadow" style="position: fixed; bottom: 0; left: 0; right: 0; z-index: 2000;">
        <span>✨ 新しいアップデートがあります！</span>
        <button class="btn btn-primary btn-sm" @onclick="UpdateAppWithOverlay">今すぐ更新</button>
    </div>
}

@code {
    private bool _isInitialized;
    private bool _newVersionAvailable = false;
    private bool _isUpdating = false; // 更新中フラグ

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // JSに自身（this）を渡し、通知を受け取れるようにする
            await JS.InvokeVoidAsync("registerUpdateNotifier", DotNetObjectReference.Create(this));
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await UserContext.InitializeAsync();
        _isInitialized = true;
    }

    [JSInvokable]
    public void ShowUpdateBanner()
    {
        _newVersionAvailable = true;
        StateHasChanged();
    }

    private async Task UpdateApp()
    {
        await JS.InvokeVoidAsync("activateUpdate");
    }

    private async Task UpdateAppWithOverlay()
    {
        _isUpdating = true; // ここでローディング表示を開始
        StateHasChanged();  // UIを即時更新

        // 少しだけウェイトを入れると「処理してる感」が出てUXが向上する
        await Task.Delay(500);

        await JS.InvokeVoidAsync("activateUpdate");
    }
}