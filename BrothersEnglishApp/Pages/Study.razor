@page "/study"
@using BrothersEnglishApp.Models
@using BrothersEnglishApp.Services
@implements IAsyncDisposable
@inject IJSRuntime JS
@inject LocalStorageService Storage
@inject NavigationManager Nav
@inject UserContext Context
@inject SpeechService Speech
@inject WordRepository WordRepo
@inject TrainingEngine Engine

<PageTitle>学習ページ</PageTitle>

@if (_currentWord == null)
{
    @* --- 目標達成画面（省略なし） --- *@
    <div class="text-center mt-5">
        <span class="display-1">🎉</span>
        <h4 class="mt-3">今日の目標達成！</h4>
        <p class="fs-5">@(Context.CurrentUser)くん、よく頑張ったね！</p>
        <div class="d-grid gap-3 col-10 col-md-6 mx-auto mt-4">
            <button class="btn btn-outline-primary btn-lg py-3" @onclick="AddMoreStudy">
                <i class="bi bi-plus-circle-fill me-2"></i>まだいける！もっと覚える
            </button>
            <button class="btn btn-success btn-lg py-3" @onclick='() => Nav.NavigateTo("training")'>
                <i class="bi bi-play-circle-fill me-2"></i>今日の復習をする
            </button>
        </div>
    </div>
}
else
{
    <div class="container-fluid mt-2 text-center training-page">
        @* --- ヘッダー・進捗 --- *@
        <StudyProgressBar Title="Word" 
             Current="@GetCurrentProgress()" 
             Total="@((_userProgress?.Settings?.WordStudyGoal ?? 10) + _extraGoal)" />

        @* --- 学習カード --- *@
        <div class="card shadow-sm p-3 mb-2">
            <div class="bg-light py-3 rounded mb-3" style="min-height: 80px; display: flex; flex-direction: column; align-items: center; justify-content: center;">
                @if (_isReviewing || !_isStep2)
                {
                    <h2 class="display-4 fw-bold text-primary mb-0">@_currentWord.Word</h2>
                    <div class="text-muted fs-4 ps-1">@_currentWord.IPA</div>
                }
                else
                {
                    <h2 class="display-4 fw-bold text-muted mb-0" style="opacity: 0.1;">????</h2>
                }
            </div>

            <div class="mb-3">
                <span class="badge bg-success">@_currentWord.PartOfSpeech</span>
                <button class="btn btn-outline-primary rounded-circle ms-2" @onclick="() => Speak(_currentWord.Word)">
                    <i class="bi bi-volume-up-fill"></i>
                </button>
                <h2 class="fw-bold mt-2">@_currentWord.Meaning</h2>
            </div>

            @if (_isReviewing)
            {
                <button class="btn btn-danger btn-lg w-100 py-4 fs-3" @onclick="EndReview">もう一度入力する🚀</button>
            }
            else
            {
                <input class="form-control form-control-lg text-center fs-1 @(_isWrong ? "is-invalid" : "")"
                       @bind="_userInput" @bind:event="oninput" @onkeyup="HandleKeyUp"
                       readonly="@IsMobile" placeholder="@(IsMobile ? "下で打ってね" : "入力してね")" />
            }
        </div>
    </div>

    @* --- 【ここがポイント】共通コンポーネントを配置 --- *@
    <VirtualKeyboard @ref="_keyboard" 
                     Visible="!_isReviewing" 
                     OnInput="val => { _userInput = val; StateHasChanged(); }" 
                     OnEnter="CheckAnswer" />
}

@code {
    private List<EnglishWord>? _allWords;
    private UserProgress? _userProgress;
    private EnglishWord? _currentWord;
    private string _userInput = ""; // 一箇所に統合
    private bool _isStep2, _isCorrect, _isReviewing, _isWrong;
    private int _extraGoal;
    private bool IsMobile;
    private VirtualKeyboard? _keyboard;

    protected override async Task OnInitializedAsync()
    {
        if (!Context.IsSelected) { Nav.NavigateTo("/"); return; }
        _allWords = await WordRepo.GetWordsAsync();
        _userProgress = await Storage.LoadUserProgressAsync(Context.CurrentUserId) ?? new UserProgress();
        await SelectNextWord();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var ua = await JS.InvokeAsync<string>("speechHandlers.getUserAgent");
            IsMobile = ua.Contains("iPhone") || ua.Contains("Android") || ua.Contains("iPad");
            StateHasChanged();
        }
    }
    // --- 答え合わせのロジックもエンジンに任せる --- //
    private async Task CheckAnswer()
    {
        if (_currentWord == null || _isReviewing) return;
        var result = Engine.ProcessAnswer(_userInput, _currentWord, _userProgress!, _isStep2);

        if (result.IsCorrect)
        {
            _isCorrect = true; StateHasChanged();
            await Storage.SaveUserProgressAsync(Context.CurrentUserId, _userProgress!);
            await Task.Delay(600);
            if (result.ShouldGoToStep2) { _isStep2 = true; await ResetInput(); }
            else if (result.IsFinished) { await SelectNextWord(); }
        }
        else
        {
            if (result.ShouldStartReview) { _isReviewing = true; await ResetInput(); }
            else { _isWrong = true; StateHasChanged(); await Task.Delay(500); _isWrong = false; await ResetInput(); }
        }
    }
    // --- 入力リセットも一箇所にまとめる --- //
    private async Task ResetInput()
    {
        _userInput = "";
        if (_keyboard != null) await _keyboard.ClearAsync();
        StateHasChanged();
    }
    // --- 次の単語を選ぶロジックもエンジンに任せる --- //
    private async Task SelectNextWord()
    {
        int effectiveGoal = (_userProgress?.Settings.WordStudyGoal ?? 10) + _extraGoal;
        _currentWord = Engine.GetNextWord(_allWords!, _userProgress!, effectiveGoal);
        _isStep2 = _isCorrect = _isReviewing = false;
        await ResetInput();
        if (_currentWord != null && _userProgress!.Settings.IsAutoSpeechEnabled) await Speak(_currentWord.Word);
        else if (_currentWord == null) 
        {
            _userProgress!.ActivityLog[_userProgress.GetTodayKey()].StudyDone = true;
            await Storage.SaveUserProgressAsync(Context.CurrentUserId, _userProgress);
        }
    }

    private async Task EndReview() { _isReviewing = false; await ResetInput(); }
    private async Task HandleKeyUp(KeyboardEventArgs e) { if (e.Key == "Enter") await CheckAnswer(); }
    // --- 音声再生は専用メソッドにまとめる --- //
    private async Task Speak(string text)
    {
        if (_userProgress != null)
        {
            await Speech.SpeakAsync(text, _userProgress.Settings.WordSpeechRate);
        }
    }
    
    private int GetCurrentProgress() => (_userProgress?.WordStatuses.Count(s => s.LastReviewed.Date == DateTime.UtcNow.Date && s.Status >= 1) ?? 0) + 1;
    private async Task AddMoreStudy() { _extraGoal += 5; await SelectNextWord(); }

    public async ValueTask DisposeAsync() { /* VirtualKeyboard側で破棄 */ }
}