@page "/training"
@inherits StudyPageBase
@inject WordRepository WordRepo
@inject TrainingEngine Engine
@inject LocalStorageService Storage
@inject NavigationManager Navigation

<PageTitle>今日の復習</PageTitle>

<div class="container mt-4">
    @* --- 判定用オーバーレイ --- *@
    @if (_showOverlay)
    {
        <div class="overlay-container">
            @if (_isLastAnswerCorrect)
            {
                <div class="huge-symbol text-success animate__animated animate__bounceIn">○</div>
            }
            else
            {
                <div class="huge-symbol text-danger animate__animated animate__shakeX">×</div>
            }
        </div>
    }

    @* --- メインコンテンツ --- *@
    @if (_isFinished)
    {
        <div class="text-center animate__animated animate__fadeIn">
            <h2 class="fw-bold">おつかれさま、かん！</h2>
            <p class="text-muted">今日の単語学習はこれでバッチリだぜ。</p>
            <div class="display-1 text-success mb-4">
                <i class="bi bi-trophy-fill"></i>
            </div>

            <div class="d-grid gap-3 col-md-6 mx-auto">
                <button class="btn btn-primary btn-lg shadow" @onclick='() => Navigation.NavigateTo("sentence-study")'>
                    <i class="bi bi-pencil-square"></i> 文のトレーニングに進む
                </button>
                <button class="btn btn-outline-secondary" @onclick="GoReport">
                    <i class="bi bi-graph-up"></i> 今日の成績を見る
                </button>
            </div>
        </div>
    }
    else if (_currentQuestion != null)
    {
        <StudyProgressBar Title="Training"
                          Current="@(_doneCount + 1)"
                          Total="@_studyGoal" />

        <div class="card shadow-sm mx-auto @(IsMobile ? "w-100" : "") @(_showOverlay ? "training-card-overlay" : "training-card-active")"
             style="max-width: 500px;">
            <div class="card-body text-center p-5">
                <p class="text-muted">@(_currentQuestion.IsEnglishToJapanese ? "これの意味は？" : "これは英語で？")</p>
                <h1 class="display-4 mb-4">@_currentQuestion.QuestionText</h1>
                <div class="d-grid gap-3">
                    @foreach (var option in _currentQuestion.Options)
                    {
                        <button @key="option"
                                class="btn btn-outline-primary @(IsMobile ? "btn-lg py-4" : "py-3") fs-4 quiz-button"
                                @onclick="(e) => HandleAnswer(option, e)">
                            @option
                        </button>
                    }
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="text-center">
            <p>きょう おぼえた単語を よみこみ中...</p>
        </div>
    }
</div>

@code {
    private List<EnglishWord> _allWords = new();
    private UserProgress? _userProgress;
    private Question? _currentQuestion;
    private int _studyGoal = 10;
    private int _doneCount = 0;
    private bool _isFinished = false;
    private bool _showOverlay = false;
    private bool _isLastAnswerCorrect = false;

    protected override async Task OnInitializedAsync()
    {
        _allWords = await WordRepo.GetWordsAsync();
        _userProgress = await Storage.LoadProgressAsync();

        if (_userProgress != null)
        {
            _studyGoal = _userProgress.Settings.WordTrainingGoal > 0 ? _userProgress.Settings.WordTrainingGoal : 10;
        }
        await GenerateNextQuestion();
    }

    // --- ライフサイクル（StudyPageBase でスマホ判定が終わった後に呼ばれる） ---
    protected override async Task OnPageFirstRenderAsync()
    {
        if (_userProgress != null && !_userProgress.WordStatuses.Any())
        {
            // 1. AppService 経由でアラート表示
            await AppService.AlertAsync("まだ覚えた単語がないみたいだぜ。まずは「覚える」から始めてみよう！");
            Navigation.NavigateTo("study");
        }
    }

    private async Task HandleAnswer(string selected, MouseEventArgs e)
    {
        if (_showOverlay || _currentQuestion == null) return;

        // 2. AppService 経由に統一（フォーカス解除）
        await AppService.BlurActiveElementAsync();

        bool isCorrect = (selected == _currentQuestion.CorrectAnswer);

        if (isCorrect) await AppService.PlayCorrectSoundAsync();
        else await AppService.PlayIncorrectSoundAsync();

        if (_userProgress != null)
        {
            Engine.RecordStudyResult(_userProgress, _currentQuestion.WordId, isCorrect);
            await Storage.SaveProgressAsync(_userProgress);
        }

        _isLastAnswerCorrect = isCorrect;
        _showOverlay = true;
        StateHasChanged();

        await Task.Delay(800);
        _showOverlay = false;

        if (isCorrect)
        {
            _doneCount++;
            await GenerateNextQuestion();
        }
        StateHasChanged();
    }

    private async Task GenerateNextQuestion()
    {
        if (_doneCount >= _studyGoal)
        {
            await FinishStudy();
            return;
        }

        _currentQuestion = Engine.GenerateStudyQuestion(_allWords, _userProgress);
        // スクロールも AppService から呼ぶ
        await AppService.ScrollToTopAsync();
        StateHasChanged();
    }

    private async Task FinishStudy()
    {
        _isFinished = true;
        if (_userProgress != null)
        {
            var todayKey = _userProgress.GetTodayKey();
            if (!_userProgress.ActivityLog.ContainsKey(todayKey))
                _userProgress.ActivityLog[todayKey] = new DayActivity();

            _userProgress.ActivityLog[todayKey].TrainingDone = true;
            await Storage.SaveProgressAsync(_userProgress);
        }
        StateHasChanged();
    }

    private void GoReport() => Navigation.NavigateTo("report");
}