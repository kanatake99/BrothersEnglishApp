@page "/sentence-training"
@using BrothersEnglishApp.Models
@using BrothersEnglishApp.Services
@using BrothersEnglishApp.Shared
@* 1. 基底クラスを継承。KeyboardServiceやIsMobile判定、UserInput管理を共通化 *@
@inherits StudyPageBase
@inject WordRepository WordRepo
@inject SentenceEngine Engine
@inject LocalStorageService Storage
@inject NavigationManager Navigation

<PageTitle>文の復習</PageTitle>

<div class="container mt-4">
    @if (_showOverlay)
    {
        <div class="overlay-container">
            @if (_isLastAnswerCorrect)
            {
                <div class="huge-symbol text-success animate__animated animate__bounceIn">○</div>
            }
            else
            {
                <div class="huge-symbol text-danger animate__animated animate__shakeX">×</div>
            }
        </div>
    }

    @if (_isFinished)
    {
        <div class="text-center">
            <h2>トレーニング完了！</h2>
            <p>今日の復習はバッチリ。</p>
            <div class="display-1 text-success mb-4"><i class="bi bi-check-circle-fill"></i></div>
            <button class="btn btn-primary btn-lg" @onclick="() => Navigation.NavigateTo(string.Empty)">ホームへ戻る</button>
        </div>
    }
    else if (_currentQuestion != null)
    {
        <StudyProgressBar Title="Sentence Training"
                          Current="@(_doneCount + 1)"
                          Total="@_totalGoal" />

        <div class="card shadow-sm mx-auto" style="max-width: 600px;">
            <div class="card-body p-4 text-center @(_isPenaltyMode ? "is-typing" : "")">
                <h5 class="text-muted mb-4">@_currentQuestion.Sentence.Japanese</h5>
 
                <div class="mb-4">
                    <h2 class="display-6 lh-base">
                        @foreach (var segment in _sentenceSegments)
                        {
                            if (segment.IsTarget)
                            {
                                var targetWords = segment.Text.Split(' ', StringSplitOptions.RemoveEmptyEntries);
                                @for (int i = 0; i < targetWords.Length; i++)
                                {
                                    var index = i;
                                    <span class="badge bg-light border-bottom border-primary text-primary px-3 mx-1 shadow-sm"
                                          style="min-width: 80px; cursor: pointer;"
                                          @onclick="UndoLastSelection">
                                        @if (_userSelections.Count > index)
                                        {
                                            @_userSelections[index]
                                        }
                                        else
                                        {
                                            <span class="text-muted opacity-50">____</span>
                                        }
                                    </span>
                                }
                            }
                            else
                            {
                                <span>@segment.Text </span>
                            }
                        }
                    </h2>
                </div>

                @if (!_isPenaltyMode)
                {
                    @* --- チップ選択モード --- *@
                    <div class="d-flex flex-wrap justify-content-center gap-2 mb-3">
                        @foreach (var chip in _currentQuestion.Chips)
                        {
                            <button class="btn btn-outline-primary btn-lg rounded-pill px-4 py-2 shadow-sm fw-bold"
                                    style="text-transform: none !important;"
                                    disabled="@(_userSelections.Contains(chip))"
                                    @onclick="() => HandleChipSelect(chip)">
                                @chip
                            </button>
                        }
                    </div>
                    <button class="btn btn-success btn-lg px-5 shadow"
                            disabled="@(!_userSelections.Any())"
                            @onclick="CheckAnswer">
                        判定！
                    </button>
                }
                else
                {
                    @* --- ペナルティ（タイピング）モード --- *@
                    <div class="alert alert-danger mb-4 animate__animated animate__shakeX">
                        <i class="bi bi-exclamation-triangle-fill"></i> 違うぜ！正しく入力！
                    </div>
                    <p class="text-muted mb-1">正解: <strong class="text-dark">@_currentQuestion.CorrectAnswer</strong></p>
                    
                    <input type="text" class="form-control form-control-lg text-center mb-3"
                           @bind="UserInput"
                           @bind:event="oninput"
                           autocomplete="off"
                           readonly="@IsMobile"
                           placeholder="タイピングしてくれ！" />
                    
                    @* 2. 基底クラスの Keyboard 変数と HandleVirtualKey を利用 *@
                    <VirtualKeyboard @ref="Keyboard" OnInput="HandleVirtualKey" OnEnter="CheckAnswer" />
                    
                    <div class="mt-3">
                        <button class="btn btn-danger btn-lg px-5 shadow" @onclick="CheckAnswer">
                            入力完了！
                        </button>
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    private List<EnglishWord> _allWords = [];
    private List<SentenceItem> _allSentences = [];
    private UserProgress? _userProgress;
    private SentenceQuestion? _currentQuestion;
    private List<SentenceSegment> _sentenceSegments = [];
    private List<string> _userSelections = new();
    private int _targetCount = 0;
    
    private int _totalGoal = 5;
    private int _doneCount = 0;
    private bool _isFinished = false;
    private bool _showOverlay = false;
    private bool _isLastAnswerCorrect = false;
    private bool _isPenaltyMode = false;

    protected override async Task OnInitializedAsync()
    {
        _allWords = await WordRepo.GetWordsAsync();
        _allSentences = await WordRepo.GetSentencesAsync();
        _userProgress = await Storage.LoadProgressAsync();
        _totalGoal = _userProgress?.Settings.SentenceTrainingGoal ?? 5;

        await LoadNextQuestion();
    }

    private async Task LoadNextQuestion()
    {
        if (_doneCount >= _totalGoal) { _isFinished = true; return; }
        var nextSentence = Engine.GetNextSentenceToTrain(_userProgress, _allSentences);
        if (nextSentence == null) { _isFinished = true; return; }
        
        _currentQuestion = Engine.GenerateSentenceTraining(nextSentence, _allWords, _allSentences);
        _sentenceSegments = Engine.SplitSentence(nextSentence.English, nextSentence.Target);
        _targetCount = nextSentence.Target.Split(' ', StringSplitOptions.RemoveEmptyEntries).Length;
    
        _userSelections.Clear();
        _isPenaltyMode = false;
        // 3. 基底クラスの ResetInputAsync を使用（UserInputとJSバッファを一括クリア）
        await ResetInputAsync();
    }

    private void HandleChipSelect(string chip)
    {
        if (_userSelections.Count < _targetCount)
        {
            _userSelections.Add(chip);
        }
    }

    private async Task CheckAnswer()
    {
        if (_currentQuestion == null || _showOverlay) return;

        bool isCorrect;
        if (_isPenaltyMode)
        {
            isCorrect = Engine.CheckAnswer(UserInput, _currentQuestion.CorrectAnswer);
        }
        else
        {
            var userFullAnswer = string.Join(" ", _userSelections);
            isCorrect = Engine.CheckAnswer(userFullAnswer, _currentQuestion.CorrectAnswer);
        }

        if (isCorrect) await AppService.PlayCorrectSoundAsync();
        else await AppService.PlayIncorrectSoundAsync();

        _isLastAnswerCorrect = isCorrect;
        _showOverlay = true;
        StateHasChanged();

        if (_userProgress != null)
        {
            Engine.UpdateProgress(_userProgress, _currentQuestion.Sentence.Id, isStudy: false, isCorrect: isCorrect);
            await Storage.SaveProgressAsync(_userProgress);
        }

        await Task.Delay(800);
        _showOverlay = false;

        if (isCorrect)
        {
            _doneCount++;
            await LoadNextQuestion();
        }
        else
        {
            _isPenaltyMode = true;
            // 4. 不正解時にタイピングモードへ移行するため、入力をリセット
            await ResetInputAsync();
        }
        StateHasChanged();
    }

    // 5. 基底クラスの HandleVirtualKey をオーバーライド
    // ペナルティモード以外（チップ選択中）はJSキーボードの入力を無視する設定
    protected override async Task HandleVirtualKey(string key)
    {
        if (!_isPenaltyMode) return;
        
        // 特殊なキー（スペース等）の処理のみ追加し、あとは基底の標準ロジックに任せる
        if (key == "{space}")
        {
            UserInput += " ";
            StateHasChanged();
        }
        else if (key == "{enter}")
        {
            await CheckAnswer();
        }
        else
        {
            // 標準的な一文字入力やBSは基底クラスのロジックを流用
            await base.HandleVirtualKey(key);
        }
    }

    private void UndoLastSelection()
    {
        if (_userSelections.Any()) _userSelections.RemoveAt(_userSelections.Count - 1);
    }
}