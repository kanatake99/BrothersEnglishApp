@page "/sentence-study"
@using BrothersEnglishApp.Models
@using BrothersEnglishApp.Services
@using BrothersEnglishApp.Shared
@implements IAsyncDisposable
@inject SentenceRepository Repo
@inject SentenceEngine Engine
@inject LocalStorageService Storage
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject SpeechService Speech

<PageTitle>文の学習 (Study)</PageTitle>

<div class="container mt-3" style="max-width: 700px;">
    @if (_questions == null)
    {
        <div class="text-center mt-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2">問題を準備中...</p>
        </div>
    }
    else if (_isFinished)
    {
        @* --- 完了画面 --- *@
        <div class="card shadow border-0 text-center p-5 animate__animated animate__fadeIn">
            <h2 class="text-success mb-4">🌟 学習完了！</h2>
            <p class="fs-5">今日の目標分をすべて終えたぜ！<br />💮カレンダーに印がついたぞ。</p>
            <button class="btn btn-primary btn-lg mt-3" @onclick='() => Nav.NavigateTo("/")'>トップへ戻る</button>
        </div>
    }
    else if (_currentQuestion != null)
    {
        @* --- プログレス・問題表示 --- *@
        <StudyProgressBar Title="Question" 
             Current="@(_currentIndex + 1)" 
             Total="@_questions.Count" 
             MissCount="@_missCount" />

        <div class="card shadow-sm border-0">
            <div class="card-body p-2 text-center">
                <div class="alert alert-info mb-4 py-3 shadow-sm">
                    <h4 class="mb-0 fs-4">@_currentQuestion.Japanese</h4>
                </div>

                @* --- 2. 穴埋め英文表示（修正後） --- *@
                <div class="fs-3 mb-4 font-monospace border-bottom pb-3">
                    @Engine.GetQuestionText(_currentQuestion.English, _currentQuestion.Target)
                </div>

                <div class="mb-4">
                    <input type="text" class="form-control form-control-lg text-center fs-2 border-primary border-2"
                           placeholder="答えを入力..."
                           @bind="_userInput" @bind:event="oninput" @onkeyup="HandleKeyUp"
                           readonly="@_isMobile" disabled="@_isCorrectState" />
                </div>

                @if (!_isCorrectState)
                {
                    <div class="d-grid gap-2">
                        <button class="btn btn-secondary btn-lg border-1" @onclick="PlayVoice">
                            <i class="bi bi-volume-up"></i> 音声を聴く
                        </button>
                        @* --- モバイルじゃない（PC）の時だけ「判定」ボタンを表示 --- *@
                        @if (!_isMobile)
                        {
                            <button class="btn btn-primary btn-lg py-3 shadow" @onclick="CheckAnswer"
                                    disabled="@string.IsNullOrWhiteSpace(_userInput)">
                                判定する (Enter)
                            </button>
                        }
                    </div>
                }
                else
                {
                    <div class="animate__animated animate__zoomIn">
                        <div class="alert alert-success fw-bold fs-4 mb-3">💮 正解！</div>
                        <div class="card bg-light border-0 mb-4 text-start">
                            <div class="card-body">
                                <h6 class="fw-bold text-primary"><i class="bi bi-lightbulb"></i> 解説ノート:</h6>
                                <p class="mb-0">@_currentQuestion.Note</p>
                            </div>
                        </div>
                        <button class="btn btn-success btn-lg w-100 py-3 shadow" @onclick="NextQuestion">
                            次の問題へ <i class="bi bi-arrow-right-circle"></i>
                        </button>
                    </div>
                }
            </div>
        </div>
    }

    @* --- 【共通コンポーネント】 --- *@
    <VirtualKeyboard @ref="_keyboard"
                     Visible="@(!_isCorrectState && !_showPopup)"
                     OnInput="val => { _userInput = val; StateHasChanged(); }"
                     OnEnter="CheckAnswer" />
</div>

@* --- 演出用ポップアップ（省略なし） --- *@
@if (_showPopup)
{
    @* ...既存のポップアップコード... *@
    <div class="modal-backdrop fade show"></div>
    <div class="modal fade show d-block" style="top: 20%">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header @(_missCount == 1 ? "bg-warning" : "bg-danger") text-white">
                    <h5 class="modal-title">@(_missCount == 1 ? "💡 ヒント" : "📖 正解の確認")</h5>
                </div>
                <div class="modal-body text-center p-4">
                    @if (_missCount == 1)
                    {
                        <p class="fs-5 mb-3">おしい！！</p>
                        <div class="p-3 bg-light rounded mb-3">@_currentQuestion?.Note</div>
                    }
                    else
                    {
                        <p class="fs-5 mb-2">もう一度確認しよう！</p>
                        <h2 class="text-primary fw-bold mb-3">@_currentQuestion?.Target</h2>
                    }
                    <button class="btn btn-dark w-100 py-2" @onclick="ClosePopup">わかった！</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<SentenceItem>? _questions;
    private SentenceItem? _currentQuestion;
    private UserProgress? _progress;
    private int _currentIndex = 0;
    private string _userInput = "";
    private int _missCount = 0;
    private bool _showPopup, _isCorrectState, _isFinished, _isMobile;
    private VirtualKeyboard? _keyboard;

    protected override async Task OnInitializedAsync()
    {
        _progress = await Storage.LoadProgressAsync();
        var all = await Repo.GetSentencesAsync();
        _questions = Engine.GetStudyQuestions(all, _progress);
        if (_questions.Count == 0) _isFinished = true;
        else _currentQuestion = _questions[_currentIndex];

        // デバイス判定だけは保持
        var ua = await JS.InvokeAsync<string>("speechHandlers.getUserAgent");
        _isMobile = ua.Contains("Android") || ua.Contains("iPhone") || ua.Contains("iPad");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // 1. まずデバイス判定を済ませる
            var ua = await JS.InvokeAsync<string>("speechHandlers.getUserAgent");
            _isMobile = ua.Contains("Android") || ua.Contains("iPhone") || ua.Contains("iPad");
            StateHasChanged();

            // 2. 1問目の音声を鳴らす
            // ブラウザのブロックを避けるため、少しだけ待機してから実行する
            await Task.Delay(500);
            await PlayVoice();
        }
    }

    private async Task CheckAnswer()
    {
        if (_currentQuestion == null || _isCorrectState) return;

        if (Engine.CheckAnswer(_userInput, _currentQuestion.Target))
        {
            _isCorrectState = true;
            _missCount = 0;
            // --- 正解したらお手本の英文を読み上げる ---
            await PlayVoice();
            Engine.UpdateProgress(_progress!, _currentQuestion.Id, isStudy: true);
            await Storage.SaveProgressAsync(_progress!);
        }
        else
        {
            _missCount++;
            _showPopup = true;
            if (_missCount >= 2 && _progress != null)
                await Speech.SpeakAsync(_currentQuestion.Target, _progress.Settings.SentenceSpeechRate);
        }
    }

    private async Task ResetInput()
    {
        _userInput = "";
        if (_keyboard != null) await _keyboard.ClearAsync();
    }

    private async Task ClosePopup()
    {
        _showPopup = false;
        await ResetInput();
    }

    private async Task NextQuestion()
    {
        _currentIndex++;
        if (_currentIndex >= _questions!.Count) _isFinished = true;
        else
        {
            _currentQuestion = _questions[_currentIndex];
            _missCount = 0;
            _isCorrectState = false;
            await ResetInput();
            await PlayVoice();
        }
    }

    private async Task PlayVoice()
    {
        if (_currentQuestion != null && _progress != null)
            await Speech.SpeakAsync(_currentQuestion.English, _progress.Settings.SentenceSpeechRate);
    }

    private async Task HandleKeyUp(KeyboardEventArgs e) { if (e.Key == "Enter") await CheckAnswer(); }
    public async ValueTask DisposeAsync() { }

}