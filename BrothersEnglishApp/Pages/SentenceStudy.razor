@page "/sentence-study"
@using BrothersEnglishApp.Models
@using BrothersEnglishApp.Services
@inject SentenceRepository Repo
@inject SentenceEngine Engine
@inject LocalStorageService Storage
@inject IJSRuntime JS
@inject NavigationManager Nav

<PageTitle>文の学習 (Study)</PageTitle>

<div class="container mt-4" style="max-width: 700px;">
    @if (_questions == null)
    {
        <div class="text-center mt-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2">問題を準備中...</p>
        </div>
    }
    else if (_isFinished)
    {
        <div class="card shadow border-0 text-center p-5 animate__animated animate__fadeIn">
            <h2 class="text-success mb-4">🌟 学習完了！</h2>
            <p class="fs-5">今日の目標分をすべて終えたぜ！<br />💮カレンダーに印がついたぞ。</p>
            <button class="btn btn-primary btn-lg mt-3" @onclick='() => Nav.NavigateTo("/")'>トップへ戻る</button>
        </div>
    }
    else if (_currentQuestion != null)
    {
        @* --- ヘッダー・進捗 --- *@
        <div class="d-flex justify-content-between align-items-center mb-2">
            <span class="badge bg-secondary">Question @(_currentIndex + 1) / @(_questions.Count)</span>
            <span class="small text-muted">ミス: @_missCount 回</span>
        </div>
        <div class="progress mb-4" style="height: 8px;">
            <div class="progress-bar bg-success" style="width: @(GetProgressPercentage())%"></div>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-body p-4 text-center">
                @* 1. 日本語表示 *@
                <div class="alert alert-info mb-4 py-3 shadow-sm">
                    <h4 class="mb-0 fw-bold">@_currentQuestion.Japaneseki-</h4>
                </div>

                @* 2. 穴埋め英文表示 *@
                <div class="fs-3 mb-4 font-monospace border-bottom pb-3">
                    @Engine.GetQuestionText(_currentQuestion.English, _currentQuestion.Target)
                </div>

                @* 入力エリア *@
                <div class="mb-4">
                    <input type="text" class="form-control form-control-lg text-center fs-2 border-primary border-2"
                           placeholder="答えを入力..."
                           @bind="_userInput"
                           @bind:event="oninput"
                           @onkeyup="HandleKeyUp"
                           readonly="@_isMobile"
                           disabled="@_isCorrectState" />
                </div>

                @if (!_isCorrectState)
                {
                    <div class="d-grid gap-2">
                        <button class="btn btn-primary btn-lg py-3 shadow" @onclick="CheckAnswer"
                                disabled="@string.IsNullOrWhiteSpace(_userInput)">
                            判定する (Enter)
                        </button>
                        <button class="btn btn-outline-secondary btn-sm border-0" @onclick="PlayVoice">
                            <i class="bi bi-volume-up"></i> 音声を聴く
                        </button>
                    </div>
                }
                else
                {
                    @* 7. 正解時の表示 *@
                    <div class="animate__animated animate__zoomIn">
                        <div class="alert alert-success fw-bold fs-4 mb-3">💮 正解！</div>
                        <div class="card bg-light border-0 mb-4 text-start">
                            <div class="card-body">
                                <h6 class="fw-bold text-primary"><i class="bi bi-lightbulb"></i> 解説ノート:</h6>
                                <p class="mb-0">@_currentQuestion.Note</p>
                            </div>
                        </div>
                        <button class="btn btn-success btn-lg w-100 py-3 shadow" @onclick="NextQuestion">
                            次の問題へ <i class="bi bi-arrow-right-circle"></i>
                        </button>
                    </div>
                }
            </div>
        </div>
    }
    @if (_isMobile)
    {
        <div class="simple-keyboard mt-4 animate__animated animate__fadeInUp"></div>
    }
</div>

@* --- 演出用ポップアップ（オーバーレイ） --- *@
@if (_showPopup)
{
    <div class="modal-backdrop fade show"></div>
    <div class="modal fade show d-block" style="top: 20%">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header @(_missCount == 1 ? "bg-warning" : "bg-danger") text-white">
                    <h5 class="modal-title">@(_missCount == 1 ? "💡 ヒント" : "📖 正解の確認")</h5>
                </div>
                <div class="modal-body text-center p-4">
                    @if (_missCount == 1)
                    {
                        <p class="fs-5 mb-3">おしい！！</p>
                        <div class="p-3 bg-light rounded mb-3">@_currentQuestion?.Note</div>
                    }
                    else
                    {
                        <p class="fs-5 mb-2">もう一度確認しよう！</p>
                        <h2 class="text-primary fw-bold mb-3">@_currentQuestion?.Target</h2>
                        <p class="small text-muted">※同じように打ってみよう！</p>
                    }
                    <button class="btn btn-dark w-100 py-2" @onclick="ClosePopup">わかった！</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<SentenceItem>? _questions;
    private SentenceItem? _currentQuestion;
    private UserProgress? _progress;
    private int _currentIndex = 0;
    private string _userInput = "";
    private int _missCount = 0;      // ミス回数
    private bool _showPopup = false;  // ポップアップ表示フラグ
    private bool _isCorrectState = false; // 正解してノート表示中か
    private bool _isFinished = false;
    private bool _isMobile = false;
    private DotNetObjectReference<SentenceStudy>? _objRef;

    protected override async Task OnInitializedAsync()
    {
        _progress = await Storage.LoadProgressAsync();
        var all = await Repo.GetSentencesAsync();
        _questions = Engine.GetStudyQuestions(all, _progress);

        if (_questions.Count == 0) _isFinished = true;
        else
        {
            _currentQuestion = _questions[_currentIndex];
            _isMobile = await CheckIfMobile();
            if (_isMobile) _objRef = DotNetObjectReference.Create(this);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && _questions?.Any() == true)
        {
            await PlayVoice(); // 1. 初回再生
            if (_isMobile) await JS.InvokeVoidAsync("setupKeyboard", _objRef);
        }
    }

    private async Task PlayVoice()
    {
        if (_currentQuestion != null && _progress != null)
            await JS.InvokeVoidAsync("speechHandlers.speak", _currentQuestion.English, _progress.Settings.SentenceSpeechRate);
    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(_userInput)) await CheckAnswer();
    }

    private async Task CheckAnswer()
    {
        if (_currentQuestion == null || _isCorrectState) return;

        if (Engine.CheckAnswer(_userInput, _currentQuestion.Target))
        {
            // 7. 正解
            _isCorrectState = true;
            _missCount = 0;
            // 進捗保存
            Engine.UpdateProgress(_progress!, _currentQuestion.Id, isStudy: true);
            await Storage.SaveProgressAsync(_progress!);
        }
        else
        {
            _missCount++;
            _showPopup = true;

            if (_missCount >= 2)
            {
                // 4. 二回以上間違えたら正しい文を読み上げ
                await JS.InvokeVoidAsync("speechHandlers.speak", _currentQuestion.Target, _progress?.Settings.SentenceSpeechRate ?? 1.0);
            }
        }
    }

    private void ClosePopup()
    {
        _showPopup = false;
        _userInput = ""; // 3, 5. 再入力のためにクリア
    }

    private async Task NextQuestion()
    {
        _currentIndex++;
        if (_currentIndex >= _questions!.Count)
        {
            _isFinished = true;
            if (_isMobile) await JS.InvokeVoidAsync("destroyKeyboard");
        }
        else
        {
            _currentQuestion = _questions[_currentIndex];
            _userInput = "";
            _missCount = 0;
            _isCorrectState = false;
            await PlayVoice();
            if (_isMobile) await JS.InvokeVoidAsync("clearKeyboard");
        }
    }

    private double GetProgressPercentage() => (_currentIndex / (double)_questions!.Count) * 100;

    private async Task<bool> CheckIfMobile()
    {
        var ua = await JS.InvokeAsync<string>("speechHandlers.getUserAgent");
        return ua.Contains("Android") || ua.Contains("iPhone") || ua.Contains("iPad");
    }

    [JSInvokable] public void OnKeyboardInput(string input) { _userInput = input; StateHasChanged(); }
    [JSInvokable] public async Task OnKeyboardEnter() => await CheckAnswer();
    public void Dispose() => _objRef?.Dispose();
}