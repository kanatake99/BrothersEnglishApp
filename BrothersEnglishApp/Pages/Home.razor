@page "/"
@inject UserContext Context
@inject NavigationManager Nav
@inject LocalStorageService Storage

<PageTitle>ホーム - BrothersEnglishApp</PageTitle>

<div class="container mt-4">
    @if (!Context.IsLoggedIn)
    {
        <div class="text-center mt-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2">ログイン画面へ いどう中...</p>
        </div>
    }
    else
    {
        <div class="text-center mb-4">
            <h1 class="display-5 fw-bold">こんにちは、@(Context.CurrentUser)くん！</h1>
            <p class="text-muted">今日は 何を 勉強する？</p>
        </div>

        @* --- メインメニュー：2段構成 --- *@
        <div class="row g-3 justify-content-center">
            @* 段落1: 単語セクション *@
            <div class="col-12 text-start ms-2 mb-0">
                <span class="badge bg-primary">🔤 単語の学習</span>
            </div>
            <div class="col-6 col-md-4">
                <div class="card h-100 shadow-sm border-success text-center p-3 btn btn-light" @onclick='() => Nav.NavigateTo("study")'>
                    <div class="display-4">📝</div>
                    <div class="card-body p-1">
                        <h6 class="card-title fw-bold mb-0">単語を覚える</h6>
                        <p class="small text-muted mb-0">Word Study</p>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-4">
                <div class="card h-100 shadow-sm border-warning text-center p-3 btn btn-light" @onclick='() => Nav.NavigateTo("training")'>
                    <div class="display-4">🏁</div>
                    <div class="card-body p-1">
                        <h6 class="card-title fw-bold mb-0">単語の復習</h6>
                        <p class="small text-muted mb-0">Word Training</p>
                    </div>
                </div>
            </div>

            @* 段落2: 文セクション *@
            <div class="col-12 text-start ms-2 mt-3 mb-0">
                <span class="badge bg-info">📖 文の学習</span>
            </div>
            <div class="col-6 col-md-4">
                <div class="card h-100 shadow-sm border-success text-center p-3 btn btn-light" @onclick='() => Nav.NavigateTo("sentence-study")'>
                    <div class="display-4">🖋️</div>
                    <div class="card-body p-1">
                        <h6 class="card-title fw-bold mb-0">文を覚える</h6>
                        <p class="small text-muted mb-0">Sentence Study</p>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-4">
                <div class="card h-100 shadow-sm border-warning text-center p-3 btn btn-light" @onclick='() => Nav.NavigateTo("sentence-training")'>
                    <div class="display-4">🏆</div>
                    <div class="card-body p-1">
                        <h6 class="card-title fw-bold mb-0">文の復習</h6>
                        <p class="small text-muted mb-0">Sentence Training</p>
                    </div>
                </div>
            </div>
        </div>

        @* --- カレンダーエリア (ロジックはほぼ共通) --- *@
        <div class="mt-5 p-3 bg-white rounded shadow-sm">
            <div class="d-flex justify-content-between align-items-center border-bottom pb-2 mb-3">
                <button class="btn btn-outline-secondary btn-sm" @onclick="() => ChangeMonth(-1)">◀ 前の月</button>
                <h5 class="mb-0 fw-bold">📅 @(_displayDate.ToString("yyyy年 MM月"))</h5>
                <button class="btn btn-outline-secondary btn-sm" @onclick="() => ChangeMonth(1)">次の月 ▶</button>
            </div>

            <table class="table table-bordered text-center calendar-table mb-1">
                <thead class="bg-light small">
                    <tr>
                        <th class="text-danger">日</th>
                        <th>月</th>
                        <th>火</th>
                        <th>水</th>
                        <th>木</th>
                        <th>金</th>
                        <th class="text-primary">土</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var week in _calendarWeeks)
                    {
                        <tr>
                            @foreach (var day in week)
                            {
                                <td class="@(day.Month != _displayDate.Month ? "text-muted opacity-25" : "") p-1">
                                    <div class="d-flex flex-column align-items-center">
                                        <span style="font-size: 0.7rem;">@day.Day</span>
                                        <div class="mark-area" style="height: 24px; font-size: 1.2rem;">
                                            @GetMark(day)
                                        </div>
                                    </div>
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
            <div class="text-end">
                <button class="btn btn-link btn-sm text-decoration-none" @onclick="GoToday">きょうに 戻る</button>
            </div>
        </div>

        <div class="text-center mt-4 mb-5">
            <button class="btn btn-link text-secondary btn-sm" @onclick="HandleLogout">
                🚪 別の 人で ログインする
            </button>
        </div>
    }
</div>

@code {
    private DateTime _displayDate = DateTime.UtcNow;
    private List<List<DateTime>> _calendarWeeks = new();
    private UserProgress? _userProgress;

    protected override async Task OnInitializedAsync()
    {
        if (!Context.IsLoggedIn)
        {
            Nav.NavigateTo("login");
            return;
        }

        // ★ 修正：型安全な LoadProgressAsync を使うぜ
        _userProgress = await Storage.LoadProgressAsync();
        GenerateCalendar();
    }

    // --- カレンダー生成・操作ロジック (省略：以前と同じ) ---
    private void GenerateCalendar()
    {
        _calendarWeeks.Clear();
        var firstDay = new DateTime(_displayDate.Year, _displayDate.Month, 1);
        var startDate = firstDay.AddDays(-(int)firstDay.DayOfWeek); // 日曜日から開始

        var current = startDate;
        for (int w = 0; w < 6; w++) // 最大6週
        {
            var week = new List<DateTime>();
            for (int d = 0; d < 7; d++)
            {
                week.Add(current);
                current = current.AddDays(1);
            }
            _calendarWeeks.Add(week);
        
            // 次の週の頭が翌月ならループを抜ける
            if (current.Month != _displayDate.Month && current.DayOfWeek == DayOfWeek.Sunday)
                break;
        }
        StateHasChanged();
    }

    private void ChangeMonth(int m) { _displayDate = _displayDate.AddMonths(m); GenerateCalendar(); }
    private void GoToday() { _displayDate = DateTime.UtcNow; GenerateCalendar(); }

    private async Task HandleLogout()
    {
        await Context.LogoutAsync();
        Nav.NavigateTo("login");
    }

    // --- 日付の「印」判定ロジック：ここを強化！ ---
    private string GetMark(DateTime date)
    {
        if (_userProgress == null) return "";
    
        // 保存形式 (yyyyMMdd) に完全に合わせるぜ！
        var key = date.ToString("yyyyMMdd");

        if (_userProgress.ActivityLog.TryGetValue(key, out var activity))
        {
            // 判定ロジック：現状実装されているもので判定
            // 文の復習 (SentenceTrainingDone) はまだ未実装なら、一旦除外しておくのが吉だ
            bool allDone = activity.StudyDone &&
                           activity.TrainingDone &&
                           activity.SentenceStudyDone;

            if (allDone) return "💮";
            if (activity.StudyDone || activity.SentenceStudyDone) return "⭐";
        }
        return "";
    }
}